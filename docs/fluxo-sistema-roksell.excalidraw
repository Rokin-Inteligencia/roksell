    {"id": "flow-rastreio-t", "type": "text", "x": 115, "y": 1596, "width": 310, "height": 40, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 1054, "version": 1, "versionNonce": 1054, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false, "fontSize": 13, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 18, "containerId": "flow-rastreio", "originalText": "Rastreio: /pedido/[id]?token=... → GET /orders/{id} (validação HMAC).", "lineHeight": 1.25},
